{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jjxf_launcher",
  "version": "0.1.0",
  "identifier": "com.bnao.jjxf-launcher",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "jjxf_launcher",
        "width": 1280,
        "height": 720,
        "minWidth": 940,
        "minHeight": 560,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all", 
    "windows": {
      "wix": {},
      "nsis": {}
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
